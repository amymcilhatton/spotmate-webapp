<h1>Add PR</h1>

<div class="card">
  <%= form_with model: @pr, data: { pr_form: true } do |form| %>
    <div>
      <%= label_tag :pr_type, "Type" %>
      <%= select_tag :pr_type, options_for_select([["Strength", "strength"], ["Endurance", "endurance"]]),
                     data: { pr_type: true } %>
    </div>

    <div data-strength-fields>
      <%= form.label :exercise, "Exercise or event" %>
      <%= form.text_field :exercise, list: "strength-exercise-list", required: true, data: { pr_exercise: true } %>
      <datalist id="strength-exercise-list">
        <% @strength_suggestions.each do |name| %>
          <option value="<%= name %>"></option>
        <% end %>
      </datalist>
      <p class="muted">Start typing to search or add a custom exercise.</p>
    </div>

    <div data-endurance-fields style="display:none">
      <%= label_tag :endurance_exercise, "Exercise or event" %>
      <%= text_field_tag "pr[exercise]", @pr.exercise, list: "endurance-exercise-list", required: true, data: { pr_exercise: true } %>
      <datalist id="endurance-exercise-list">
        <% @endurance_suggestions.each do |name| %>
          <option value="<%= name %>"></option>
        <% end %>
      </datalist>
      <p class="muted">Start typing to search or add a custom exercise.</p>
    </div>

    <div data-strength-fields>
      <%= form.label :value, "Value" %>
      <%= form.number_field :value, step: 0.1, data: { pr_value: true } %>
    </div>

    <div data-endurance-fields style="display:none">
      <%= label_tag :time_input, "Time (mm:ss or hh:mm:ss)" %>
      <%= text_field_tag :time_input, "", placeholder: "24:30", data: { pr_time: true } %>
      <%= hidden_field_tag "pr[value]", @pr.value, data: { pr_value: true } %>
      <p class="muted">We’ll convert this to seconds for now.</p>
    </div>

    <div data-strength-fields>
      <%= form.label :unit %>
      <%= form.select :unit, [["kg", "kg"], ["lb", "lb"], ["reps", "reps"]], data: { pr_unit: true } %>
    </div>

    <div data-endurance-fields style="display:none">
      <%= form.label :unit %>
      <%= select_tag "pr[unit]", options_for_select([["sec", "sec"], ["min", "min"]], @pr.unit), data: { pr_unit: true } %>
    </div>

    <div>
      <%= form.label :date %>
      <%= form.date_field :date, value: Date.current %>
    </div>

    <div>
      <%= form.label :notes, "Notes" %>
      <%= form.text_area :notes, rows: 3 %>
    </div>

    <div>
      <%= form.submit "Save PR", class: "btn" %>
    </div>
  <% end %>
</div>

<script>
  document.querySelectorAll("[data-pr-form]").forEach((form) => {
    const typeSelect = form.querySelector("[data-pr-type]");
    const strengthFields = form.querySelectorAll("[data-strength-fields]");
    const enduranceFields = form.querySelectorAll("[data-endurance-fields]");
    const timeInput = form.querySelector("[data-pr-time]");
    const valueFields = form.querySelectorAll("[data-pr-value]");
    const unitFields = form.querySelectorAll("[data-pr-unit]");
    const exerciseFields = form.querySelectorAll("[data-pr-exercise]");

    const toggle = () => {
      const isEndurance = typeSelect.value === "endurance";
      strengthFields.forEach((el) => (el.style.display = isEndurance ? "none" : "block"));
      enduranceFields.forEach((el) => (el.style.display = isEndurance ? "block" : "none"));

      exerciseFields.forEach((field) => {
        const inEndurance = field.closest("[data-endurance-fields]");
        const inStrength = field.closest("[data-strength-fields]");
        if (isEndurance && inStrength) field.disabled = true;
        if (!isEndurance && inStrength) field.disabled = false;
        if (isEndurance && inEndurance) field.disabled = false;
        if (!isEndurance && inEndurance) field.disabled = true;
      });

      valueFields.forEach((field) => {
        const inEndurance = field.closest("[data-endurance-fields]");
        const inStrength = field.closest("[data-strength-fields]");
        if (isEndurance && inStrength) field.disabled = true;
        if (!isEndurance && inStrength) field.disabled = false;
        if (isEndurance && inEndurance) field.disabled = false;
        if (!isEndurance && inEndurance) field.disabled = true;
      });
      if (timeInput) timeInput.disabled = !isEndurance;
      unitFields.forEach((field) => {
        const inEndurance = field.closest("[data-endurance-fields]");
        const inStrength = field.closest("[data-strength-fields]");
        if (isEndurance && inStrength) field.disabled = true;
        if (!isEndurance && inStrength) field.disabled = false;
        if (isEndurance && inEndurance) field.disabled = false;
        if (!isEndurance && inEndurance) field.disabled = true;
        if (isEndurance && inEndurance && field.value !== "sec" && field.value !== "min") {
          field.value = "sec";
        }
      });
    };

    const parseTime = (value) => {
      if (!value) return null;
      const parts = value.split(":").map(Number);
      if (parts.some(Number.isNaN)) return null;
      if (parts.length === 2) {
        return (parts[0] * 60) + parts[1];
      }
      if (parts.length === 3) {
        return (parts[0] * 3600) + (parts[1] * 60) + parts[2];
      }
      return null;
    };

    const syncTimeValue = () => {
      if (!timeInput) return;
      const seconds = parseTime(timeInput.value);
      if (!seconds) return;
      const unitField = Array.from(unitFields).find((field) => !field.disabled);
      const unitValue = unitField ? unitField.value : "sec";
      const normalized = unitValue === "min" ? seconds / 60.0 : seconds;
      valueFields.forEach((field) => {
        if (!field.disabled) field.value = normalized;
      });
    };

    if (timeInput) {
      timeInput.addEventListener("input", syncTimeValue);
    }

    form.addEventListener("submit", () => {
      if (typeSelect.value === "endurance") {
        syncTimeValue();
      }
    });

    typeSelect.addEventListener("change", toggle);
    toggle();
  });
</script>
