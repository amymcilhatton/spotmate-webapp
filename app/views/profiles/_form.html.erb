<%= form_with model: @profile, url: profile_path, method: :patch, multipart: true do |f| %>
  <p class="muted">Only your name and age are visible by default. You control what else to share.</p>

  <h2>Identity & basic info</h2>
  <div>
    <%= label_tag "profile[name]", "Name" %>
    <%= text_field_tag "profile[name]", current_user.name, placeholder: "Your name" %>
    <p class="muted">We show your first name on your profile.</p>
  </div>
  <div>
    <%= f.label :avatar, "Profile photo" %>
    <%= f.file_field :avatar %>
    <% if current_user.avatar.attached? %>
      <label>
        <%= check_box_tag "profile[remove_avatar]", "1", false %>
        Remove current photo
      </label>
    <% end %>
    <p class="muted">PNG, JPG, or WebP. Max 2MB.</p>
  </div>
  <div>
    <%= f.label :age %>
    <%= f.number_field :age, min: 16, max: 100 %>
  </div>

  <div>
    <%= f.label :gender %>
    <%= f.select :gender,
                    [["Female", "female"], ["Male", "male"], ["Non-binary", "non_binary"], ["Prefer not to say", "prefer_not_say"]],
                    include_blank: true %>
  </div>

  <div>
    <%= f.label :home_gym_name, "Gym name" %>
    <%= f.text_field :home_gym_name %>
  </div>

  <div>
    <%= f.label :home_city, "Gym location" %>
    <%= f.text_field :home_city %>
  </div>

  <div data-controller="gym-map">
    <%= f.label :gym_postcode, "Gym postcode" %>
    <div class="btn-row" style="margin-top: 0;">
      <%= f.text_field :gym_postcode, data: { "gym-map-target": "postcode" } %>
      <button type="button" class="btn btn-ghost" data-action="click->gym-map#searchPostcode">Find on map</button>
    </div>
    <div data-gym-map-target="map" style="height: 300px; border-radius: 12px; overflow: hidden; margin-top: 8px;">
      <%= f.hidden_field :gym_latitude, data: { "gym-map-target": "lat" } %>
      <%= f.hidden_field :gym_longitude, data: { "gym-map-target": "lng" } %>
    </div>
  </div>

  <div>
    <%= f.label :travel_preference, "Willingness to travel" %>
    <%= f.select :travel_preference,
                    [["Same gym only", "same_gym_only"], ["Gyms within my city", "same_city"],
                     ["I'm flexible / different gyms are fine", "flexible"]],
                    include_blank: false %>
  </div>

  <div>
    <%= f.label :experience_band, "Experience level" %>
    <%= f.select :experience_band,
                    [["Beginner (0–1 year lifting)", "beginner"],
                     ["Intermediate (1–3 years)", "intermediate"],
                     ["Experienced (3+ years)", "experienced"]],
                    include_blank: true %>
  </div>

  <div>
    <%= f.label :goals, "Goals / interests" %>
    <div class="grid">
      <% Profile::GOAL_OPTIONS.each do |goal| %>
        <label>
          <%= check_box_tag "profile[goals][]", goal, @profile.goals.include?(goal), id: "goal_#{goal}" %>
          <%= goal.humanize %>
        </label>
      <% end %>
    </div>
  </div>

  <h2>Who you'd like to match with</h2>
  <div>
    <%= f.label :match_radius_miles, "Match distance" %>
    <div class="btn-row" style="align-items: center; margin-top: 0;">
      <%= f.range_field :match_radius_miles, in: 0..100, step: 5, id: "match_radius_slider" %>
      <span id="match_radius_value" class="muted"><%= f.object.match_radius_miles %> miles</span>
    </div>
    <p class="muted">We’ll prioritise matches whose gyms are within this distance of yours.</p>
  </div>
  <div>
    <%= f.label :preferred_partner_age_min, "Preferred buddy age range" %>
    <div class="btn-row">
      <%= f.number_field :preferred_partner_age_min, min: 16, max: 100, placeholder: "Min age" %>
      <%= f.number_field :preferred_partner_age_max, min: 16, max: 100, placeholder: "Max age" %>
    </div>
  </div>

  <div>
    <%= f.label :preferred_buddy_days, "Preferred training days" %>
    <div class="grid">
      <% Profile::BUDDY_DAY_OPTIONS.each do |day| %>
        <label>
          <%= check_box_tag "profile[preferred_buddy_days][]", day, @profile.preferred_buddy_days.include?(day),
                            id: "buddy_day_#{day}" %>
          <%= day.capitalize %>
        </label>
      <% end %>
    </div>
  </div>

  <div>
    <%= f.label :preferred_buddy_times, "Preferred time of day" %>
    <div class="grid">
      <% Profile::TIME_OF_DAY_OPTIONS.each do |slot| %>
        <label>
          <%= check_box_tag "profile[preferred_buddy_times][]", slot,
                            @profile.preferred_buddy_times.include?(slot),
                            id: "buddy_time_#{slot}" %>
          <%= slot.humanize %>
        </label>
      <% end %>
    </div>
  </div>

  <div>
    <%= f.label :women_only, "Women-only matching" %>
    <%= f.check_box :women_only, disabled: @profile.gender == "male" %>
    <% if @profile.gender == "male" %>
      <p class="muted">Women-only matching is available to users who don’t identify as men.</p>
    <% end %>
  </div>

  <div>
    <%= f.submit "Save profile", class: "btn" %>
  </div>
<% end %>

<script>
  document.addEventListener("turbo:load", () => {
    const slider = document.getElementById("match_radius_slider");
    const valueLabel = document.getElementById("match_radius_value");
    if (!slider || !valueLabel) return;
    const updateLabel = () => {
      valueLabel.textContent = `${slider.value} miles`;
    };
    slider.oninput = updateLabel;
    updateLabel();
  });
</script>
