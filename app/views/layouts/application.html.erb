<!DOCTYPE html>
<html>
  <head>
    <title>Spotmate</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload", type: "module" %>
  </head>

  <body>
    <div class="app-shell">
      <% if user_signed_in? %>
        <nav class="top-nav">
          <div class="brand">SpotMate</div>
          <div class="nav-links">
            <%= link_to "Dashboard", root_path %>
            <%= link_to "Profile", profile_path %>
            <%= link_to "Availability", availability_slots_path %>
            <%= link_to "Matches", matches_path %>
            <%= link_to "Sessions", bookings_path %>
            <%= link_to "Activity", workout_logs_path %>
            <%= link_to "PRs", prs_path %>
            <%= link_to "Buddies", buddies_path %>
          </div>
          <div class="nav-actions">
            <%= button_to "Sign out", destroy_user_session_path, method: :delete, class: "btn btn-ghost" %>
          </div>
        </nav>
      <% end %>

      <main class="content container">
        <% if notice.present? %>
          <p class="notice"><%= notice %></p>
        <% end %>
        <% if alert.present? %>
          <p class="alert"><%= alert %></p>
        <% end %>

        <%= yield %>
      </main>
    </div>
  </body>
</html>
