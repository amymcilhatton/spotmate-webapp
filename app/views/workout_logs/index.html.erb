<div class="sessions-header">
  <div>
    <h1>Activity</h1>
    <p class="muted">Track your workouts, progress, and personal bests.</p>
  </div>
  <div class="btn-row">
    <%= link_to "Log workout", new_workout_log_path(mode: :manual), class: "btn btn-primary" %>
    <%= link_to "Generate AI workout", new_workout_log_path(mode: :ai), class: "btn btn-secondary" %>
  </div>
</div>

<% if @workout_logs.any? %>
  <% if @latest_prs.any? %>
    <div class="card">
      <h3 class="card-title">🏅 Personal bests</h3>
      <ul class="slot-list">
        <% @latest_prs.each do |pr| %>
          <li class="slot-row">
            <strong><%= pr.exercise %></strong>
            · <%= pr.value %> <%= pr.unit %>
            · <%= pr.date %>
          </li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="sessions-grid">
    <% @workout_logs.each do |log| %>
      <% payload = log.payload_json.is_a?(Hash) ? log.payload_json : {} %>
      <% exercises = Array(payload["exercises"] || payload["movements"] || payload["lifts"]) %>
      <% top_exercises = exercises.first(3) %>
      <% more_count = [exercises.size - top_exercises.size, 0].max %>
      <div class="card">
        <div class="workout-log-card-header">
          <p class="workout-log-card-date">
            📈 <%= log.date.strftime("%a %d %b") if log.date.present? %>
          </p>
          <% if log.title.present? %>
            <p class="workout-log-card-title"><%= log.title %></p>
          <% end %>
        </div>
        <% if log.date.present? && current_user.prs.where("date = ?", log.date).exists? %>
          <span class="badge">PR</span>
        <% end %>
        <% if log.notes.present? %>
          <%= render "workout_text", workout_log: log %>
        <% end %>
        <div class="btn-row">
          <%= link_to "Edit", edit_workout_log_path(log), class: "btn btn-ghost" %>
          <%= button_to "Delete",
                        workout_log_path(log),
                        method: :delete,
                        class: "btn btn-ghost",
                        data: { turbo_confirm: "Delete this workout?" } %>
        </div>
      </div>
    <% end %>
  </div>
<% else %>
  <div class="card empty-state">
    <p>You haven’t logged any workouts yet.</p>
    <p class="muted">Tracking your sessions helps improve your matches and progress.</p>
    <%= link_to "Log your first workout", new_workout_log_path(mode: :manual), class: "btn" %>
  </div>
<% end %>

<script>
  function toggleWorkout(button) {
    var card = button.closest('.workout-log-card');
    if (!card) return;

    var body = card.querySelector('.workout-body');
    if (!body) return;

    if (body.style.maxHeight && body.style.maxHeight !== 'none') {
      body.style.maxHeight = 'none';
      button.textContent = 'View less';
    } else {
      body.style.maxHeight = '220px';
      button.textContent = 'View more';
      card.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }
  }
</script>

<script>
  document.addEventListener("DOMContentLoaded", function () {
    document.querySelectorAll("[data-workout-collapsible='true']").forEach(function(card) {
      const body = card.querySelector(".workout-body");
      const toggle = card.querySelector(".workout-toggle");
      if (!body || !toggle) return;

      toggle.addEventListener("click", function () {
        const isCollapsed = body.classList.contains("workout-body--collapsed");

        if (isCollapsed) {
          body.classList.remove("workout-body--collapsed");
          toggle.textContent = "View less";
        } else {
          body.classList.add("workout-body--collapsed");
          toggle.textContent = "View more";
          card.scrollIntoView({ behavior: "smooth", block: "start" });
        }
      });
    });
  });
</script>

