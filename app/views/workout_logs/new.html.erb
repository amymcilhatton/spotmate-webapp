<h1>New workout</h1>

<div>
  <div class="card">
    <%= form_with model: @workout_log do |form| %>
      <div>
        <%= form.label :date, "Date" %>
        <%= form.date_field :date, required: true %>
      </div>

      <div>
        <%= form.label :title, "Title" %>
        <%= form.text_field :title, placeholder: "Push session" %>
      </div>

      <div>
        <%= form.label :notes, "Workout details" %>
        <%= form.text_area :notes,
                           id: "workout_log_notes",
                           rows: 12,
                           class: "form-control" %>
      </div>

      <div class="mt-4">
        <%= form.label :shared_with_buddies, class: "inline-flex items-center gap-2 text-sm text-slate-200" do %>
          <%= form.check_box :shared_with_buddies, class: "rounded border-slate-600" %>
          <span>Share this workout with my buddies</span>
        <% end %>
        <p class="text-xs text-slate-500 mt-1">
          Shared workouts appear in your buddies feed so they can comment and give kudos.
        </p>
      </div>

      <div class="btn-row">
        <button type="button" class="btn btn-secondary" id="insert-workout-template-button">
          Insert workout template
        </button>
        <%= form.submit "Save workout", class: "btn" %>
        <%= link_to "Back", workout_logs_path, class: "btn btn-ghost" %>
      </div>
    <% end %>
  </div>
</div>

<script>
  (function() {
    var button = document.getElementById("insert-workout-template-button");
    var box = document.getElementById("workout_log_notes");
    if (!button || !box) return;

    button.addEventListener("click", function(event) {
      event.preventDefault();
      box.value = "Today’s session: _______________________\n\n" +
                  "Warm-up (8–10 min)\n" +
                  "Main lifts (30–35 min)\n" +
                  "Accessory work (10–15 min)\n" +
                  "Cool-down (5–10 min)\n" +
                  "Key notes\n";
      box.focus();
    });
  })();
</script>
